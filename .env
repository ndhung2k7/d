# Máy chủ
PORT=3000

# Token Hastebin (đăng ký tại https://hastebin.com)
HASTEBIN_TOKEN=your_hastebin_token_here

# Khóa API (đăng ký tại các trang tương ứng)
ANONLINK_API_KEY=your_anonlink_api_key
LINKX_API_KEY=your_linkx_api_key
MUAL_API_KEY=your_mual_api_key

# Cấu hình mặc định
DEFAULT_TITLE=📌 LINK ĐÃ ĐƯỢC RÚT GỌN
DEFAULT_FORMAT=[TIÊU ĐỀ DO NGƯỜI DÙNG CÀI ĐẶT]\n{link}
